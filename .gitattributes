* text=auto

# Shell scripts must check out with LF everywhere — the portable folder is
# meant to be copied from a Windows clone straight onto Linux/macOS machines,
# and a CRLF shebang line breaks bash.
*.sh text eol=lf
scripts/pcoder text eol=lf

# Windows batch files require CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
